                <div style="background: rgba(14, 165, 233, 0.1); border: 1px solid rgba(14, 165, 233, 0.2); padding: 20px; border-radius: 12px; width: 100%; max-width: 850px; text-align: center; font-size: 1.2rem; font-weight: 600; color: #38bdf8; margin-bottom: 20px;">
